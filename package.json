{
  "name": "film-color-script-generator",
  "version": "0.1.0",
  "description": "Client-side tool that samples video key frames and exports scene palettes as horizontal color-script strips.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/film-color-script-generator.git"
  },
  "homepage": "https://baditaflorin.github.io/film-color-script-generator/",
  "scripts": {
    "prepare:ffmpeg": "node scripts/copy-ffmpeg-core.mjs",
    "build:meta": "node scripts/build-meta.mjs",
    "clean:pages": "node scripts/clean-pages.mjs",
    "dev": "npm run prepare:ffmpeg && npm run build:meta && vite --host 0.0.0.0",
    "build": "npm run prepare:ffmpeg && npm run build:meta && npm run clean:pages && vite build && node scripts/finalize-pages.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "pages-preview": "npm run build && node scripts/serve-pages.mjs --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "smoke": "bash scripts/smoke.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "fmt": "prettier --write .",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "comlink": "4.4.2",
    "lucide": "1.14.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "25.6.2",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "10.4.22",
    "eslint": "9.39.4",
    "playwright": "1.59.1",
    "postcss": "^8.5.14",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  }
}
